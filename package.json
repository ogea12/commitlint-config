{
  "name": "@ogea12/commitlint-config",
  "description": "Config' CommitLint appliquée dans les projets de l'OGEA 12",
  "version": "1.0.6",
  "engines": {
    "node": ">=24.14.0"
  },
  "type": "module",
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prebuild": "npm run format && npm run lint:fix",
    "build": "tsup",
    "postbuild": "del-cli build/**/*.d.cts",
    "prepublishOnly": "npm run build",
    "release": "release-it",
    "taze": "taze"
  },
  "homepage": "https://github.com/ogea12/commitlint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ogea12/commitlint-config.git"
  },
  "devDependencies": {
    "@ogea12/eslint-config": "^3.0.0",
    "@ogea12/prettier-config": "^2.0.0",
    "@ogea12/tsconfig": "^2.0.0",
    "@types/node": "^24.12.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "taze": "^19.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/types": "^20.4.3"
  },
  "peerDependencies": {
    "@commitlint/cli": "^20.4.3"
  },
  "author": "OGEA 12",
  "license": "MIT",
  "keywords": [
    "ogea12",
    "commitlint"
  ],
  "prettier": "@ogea12/prettier-config",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}",
      "web": true
    }
  }
}
